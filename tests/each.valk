
test "Each" {
    let a = Array[uint]{ 1, 2, 3, 4, 5 }

    assert(a.length == 5)
    let count = 0
    each a as nr, i {
        assert(nr == a[i])
        count++
    }
    assert(count == 5)

    // Skip

    assert(a.length == 5)
    count = 0
    each a skip 2 as nr, i {
        assert(nr == a[i])
        count++
    }
    assert(count == 3)
}
