
use valk:core
use valk:time

test "Process" {
    #if OS == win
    let p = core:Process.run("hh.exe", null, false) ! {
        assert(false)
        return
    }
    #else
    let p = core:Process.run("ls", .{ "-l" }, false) ! {
        assert(false)
        return
    }
    #end
    assert(p.did_exit() == false)
    time:sleep_ms(300)
    assert(p.did_exit() == true)
}
