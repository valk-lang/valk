
use valk:template
use valk:fs
use valk:html

test "Templates" {

    let data = object { 
        title: "Hello"
        content: object {
            msg: "World"
            attr: "\" class=\"test\""
            xss: "<script>alert('test');</script>"
        }
        test: null[String]
    }

    let vdir = __DIR__ + "/assets/views"
    let options = template:RenderOptions {
        sanitize: html:sanitize_filter
    }

    let files = #embed_dir("tests/assets/views")
    template:set_content_many(files)
    let result = template:render("pages/test-page.html", data, options) !? E.message
    let expect = fs:read(vdir + "/expect/result-1.html") !? "-?-"

    assert(result == expect)
}

test "Template extending" {

    let data = object { 
        title: "Hello"
        content: object {
            msg: "World"
            js: "<script>alert('test');</script>"
        }
    }

    let vdir = __DIR__ + "/assets/views"
    let options = template:RenderOptions {
        sanitize: html:sanitize_filter
    }

    let files = #embed_dir("tests/assets/views")
    template:set_content_many(files)
    let result = template:render("pages/test-extend.html", data, options) !? E.message
    let expect = fs:read(vdir + "/expect/result-2.html") !? "-?-"

    assert(result == expect)
}

test "Template error" {

    let data = object { 
        title: "Hello"
    }

    let files = #embed_dir("tests/assets/views")
    template:set_content_many(files)
    let result = template:render("pages/test-error.html", data) !? E.message
    assert(result.contains("No block found"))
}