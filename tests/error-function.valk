
fn test_err_func_throw(val: &uint) !AnError $throw {
    val[0]++
    throw AnError.error
}
fn test_err_func(val: &uint) !AnError {
    if val[0] == 0 : test_err_func_throw(val)
}

test "Error function" {
    let v : uint = 0
    let has_err = false
    test_err_func(&v) ! has_err = true
    assert(has_err)
    assert(v == 1)

    has_err = false
    test_err_func(&v) ! has_err = true
    assert(!has_err)
    assert(v == 1)
}