
use valk:validate
use valk:json

test "String validation" {
    // Success
    assert(validate:email("test@gmail.com") == true)
    assert(validate:email("TEST123@gmail.com") == true)
    assert(validate:email("test@Gmail.com") == true)
    assert(validate:email("test@gmail.com1") == true)
    assert(validate:email("--test--@gmail.com") == true)
    assert(validate:email("test@gm-ail.com") == true)
    assert(validate:email("test@gmail.co-m") == true)
    // Fail
    assert(validate:email("test@gmail._com") == false)
    assert(validate:email("test@gmail.1com") == false)
    assert(validate:email("test@gmail.com_") == false)
    assert(validate:email("test+1@gmail.com") == true)
    assert(validate:email("test@gmail") == false)
    assert(validate:email("test@gmail.") == false)
    assert(validate:email("test@gmail..com") == false)
    assert(validate:email("test.@gmail.com") == false)
    assert(validate:email("test+@gmail.com") == false)
    assert(validate:email(".test@gmail.com") == false)
    assert(validate:email("+test@gmail.com") == false)
    assert(validate:email("te.+st@gmail.com") == false)
    assert(validate:email("@gmail.com") == false)
    assert(validate:email("test@..com") == false)
    assert(validate:email("test@@gmail.com") == false)
    assert(validate:email("test@gm@ail.com") == false)
    assert(validate:email("test@") == false)
    assert(validate:email("test@gmail.com-") == false)
    assert(validate:email("test@gmail.-com") == false)
    assert(validate:email("test@-gmail.com") == false)
    assert(validate:email("test@gmail-.com") == false)
}

test "Field validation" {
    let errors = Map[String]{}
    let email_field = validate:Field.string().email()
    assert(email_field.validate("test@gmail.com") == true)
    assert(email_field.validate("@gmail.com", errors) == false)
    assert((errors.get("field") !? "") == "string_email")
    validate:Field.translate_errors(errors)
    assert((errors.get("field") !? "") == "Invalid email address")

    // Json
    let data = json:decode("{ \"arr\": [1, 2], \"ob\": { \"k1\": \"v1\", \"k2\": null } }") ! {
        assert(false)
        return
    }
    let fvalid = validate:Field.object(.{
        "arr" => validate:Field.array(validate:Field.int().min(1).max(2)).min(2).max(2)
        "ob" => validate:Field.object(.{
            "k1" => validate:Field.string().equals_string("v1")
            "k2" => validate:Field.string().equals_string("v2").nullable()
        }).min(2).max(2)
    })
    errors.clear()
    assert(fvalid.validate(data, errors) == true)
    assert(errors.length == 0)

    // Invalid
    let finvalid = validate:Field.object(.{
        "arr" => validate:Field.array(validate:Field.int().min(2).max(1))
        "ob" => validate:Field.object(.{
            "k1" => validate:Field.string().equals_string("vx")
            "k2" => validate:Field.string().equals_string("v2")
        }).min(2).max(2)
    })
    errors.clear()
    assert(finvalid.validate(data, errors) == false)
    assert(errors.length == 4)
    assert((errors.get("field.arr.0") !? "") == "int_min:2")
    assert((errors.get("field.arr.1") !? "") == "int_max:1")
    assert((errors.get("field.ob.k1") !? "") == "string_equal:vx")
    assert((errors.get("field.ob.k2") !? "") == "string_invalid")
}

test "Field casting" {
    // Init array
    let d1 = json:decode("[1, 2]") ! {
        assert(false)
        return
    }
    assert(d1.is_array())

    // To strings
    let f1 = validate:Field.array(validate:Field.string())
    let c1 = f1.try_cast(d1)
    assert(d1.get_index(0).is_int())
    assert(d1.get_index(1).is_int())
    assert(c1.get_index(0).is_string())
    assert(c1.get_index(1).is_string())

    // To ints
    let f2 = validate:Field.array(validate:Field.int())
    let c2 = f2.try_cast(c1)
    assert(c1.get_index(0).is_string())
    assert(c1.get_index(1).is_string())
    assert(c2.get_index(0).is_int())
    assert(c2.get_index(1).is_int())

    // Object casting
    let d2 = json:decode("{ \"k1\": 1, \"k2\": 2.123 }") ! {
        assert(false)
        return
    }
    assert(d2.is_object())

    //
    let f3 = validate:Field.object(.{
        "k1" => validate:Field.bool()
        "k2" => validate:Field.string()
        "k3" => validate:Field.float().default(1.55)
    })
    let c3 = f3.try_cast(d2)
    assert(d2.get("k1").is_int())
    assert(d2.get("k2").is_float())
    assert(c3.get("k1").is_bool())
    assert(c3.get("k2").is_string())
    assert(c3.get("k3").is_float() && c3.get("k3").float_value == 1.55)

    //
    let f4 = validate:Field.object(.{
        "k1" => validate:Field.int()
        "k2" => validate:Field.float()
        "k3" => validate:Field.string()
    })
    let c4 = f4.try_cast(c3)
    assert(c3.get("k1").is_bool())
    assert(c3.get("k2").is_string())
    assert(c4.get("k1").is_int() && c4.get("k1").int_value == 1)
    assert(c4.get("k2").is_float() && c4.get("k2").float_value == 2.123)
    assert(c4.get("k3").is_string() && c4.get("k3").string_value == "1.55")
}
