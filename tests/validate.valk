
use valk:validate

test "String validation" {
    assert(validate:validate_email("test@gmail.com") == true)
    assert(validate:validate_email("test+1@gmail.com") == true)
    assert(validate:validate_email("test@gmail") == false)
    assert(validate:validate_email("test@gmail.") == false)
    assert(validate:validate_email("test@gmail..com") == false)
    assert(validate:validate_email("test.@gmail.com") == false)
    assert(validate:validate_email("test+@gmail.com") == false)
    assert(validate:validate_email(".test@gmail.com") == false)
    assert(validate:validate_email("+test@gmail.com") == false)
    assert(validate:validate_email("te.+st@gmail.com") == false)
    assert(validate:validate_email("@gmail.com") == false)
    assert(validate:validate_email("test@..com") == false)
    assert(validate:validate_email("test@@gmail.com") == false)
    assert(validate:validate_email("test@gm@ail.com") == false)
    assert(validate:validate_email("test@") == false)
}
