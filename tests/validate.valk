
use valk:validate

test "String validation" {
    // Success
    assert(validate:email("test@gmail.com") == true)
    assert(validate:email("TEST123@gmail.com") == true)
    assert(validate:email("test@Gmail.com") == true)
    assert(validate:email("test@gmail.COM123") == true)
    // Fail
    assert(validate:email("test+1@gmail.com") == true)
    assert(validate:email("test@gmail") == false)
    assert(validate:email("test@gmail.") == false)
    assert(validate:email("test@gmail..com") == false)
    assert(validate:email("test.@gmail.com") == false)
    assert(validate:email("test+@gmail.com") == false)
    assert(validate:email(".test@gmail.com") == false)
    assert(validate:email("+test@gmail.com") == false)
    assert(validate:email("te.+st@gmail.com") == false)
    assert(validate:email("@gmail.com") == false)
    assert(validate:email("test@..com") == false)
    assert(validate:email("test@@gmail.com") == false)
    assert(validate:email("test@gm@ail.com") == false)
    assert(validate:email("test@") == false)
}
