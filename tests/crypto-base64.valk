
use valk:crypto

fn base64_test(input: String, cmp: String) bool {
    // Encode
    let hash = crypto:base64_encode(input)
    let same1 = hash == cmp
    // Decode
    let decode = crypto:base64_decode(hash)
    let same2 = decode == input
    //
    return same1 && same2
}

test "Base64" {
    let v = ""
    let h = ""

    v = ""
    h = ""
    assert(base64_test(v, h))

    v = "This is a base64 encode/decode test"
    h = "VGhpcyBpcyBhIGJhc2U2NCBlbmNvZGUvZGVjb2RlIHRlc3Q="
    assert(base64_test(v, h))

    v = "Lorem ipsum dolor sit amet consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat. In id cursus mi pretium tellus duis convallis. Tempus leo eu aenean sed diam urna tempor. Pulvinar vivamus fringilla lacus nec metus bibendum egestas. Iaculis massa nisl malesuada lacinia integer nunc posuere. Ut hendrerit semper vel class aptent taciti sociosqu. Ad litora torquent per conubia nostra inceptos himenaeos. Lorem ipsum dolor sit amet consectetur adipiscing elit. Quisque faucibus ex sapien vitae pellentesque sem placerat. In id cursus mi pretium tellus duis convallis. Tempus leo eu aenean sed diam urna tempor. Pulvinar vivamus fringilla lacus nec metus bibendum egestas. Iaculis massa nisl malesuada lacinia integer nunc posuere. Ut hendrerit semper vel class aptent taciti sociosqu. Ad litora torquent per conubia nostra inceptos himenaeos."
    h = ""
    assert(base64_test(v, h))
}
