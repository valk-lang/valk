
use valk:crypto

test "Base64" {
    // Encode
    let content = "We are TESTING base64 encoding!"
    let hash = crypto:base64_encode(content)
    assert(hash == "V2UgYXJlIFRFU1RJTkcgYmFzZTY0IGVuY29kaW5nIQ==")
    // Decode
    let decode = crypto:base64_decode(hash)
    assert(decode == content)
}