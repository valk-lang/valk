
+ class SocketServer {
    ~ socket: Socket

    + fn accept() Connection !NetError {

        let sock = this.socket
        if sock.closed : throw .closed

        let sock_fd = sock.fd
        let fd = accept(sock_fd, sock.addrinfo) !>

        return Connection.new(fd)
    }

    + fn close() {
        this.socket.close()
    }
}

