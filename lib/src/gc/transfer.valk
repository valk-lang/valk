
use mem

fn check_transfer(item: ptr) ptr {
    let state = @ptrv(item, ptr, -1)
    if state & 1 == 1 {
        return (state & -2)
    }
    return item
}

fn transfer(item: ptr) ptr {
    let base = @ptr_offset(item, -8)
    let data = base @as GcData
    let size = data.size * 8
    if size == 0 : return item
    let new = mem:alloc(size)
    mem:copy(base, new, size)
    let result = new + 8
    @ptrv(base, ptr) = result | 1
    return result
}
