
use ext

- global buffer : ByteBuffer (.new(128))

global cli_args : Array[String] (@undefined)

+ fn exit(code: i32) @willexit $global {
    ext:exit(code.@cast(i32))
}

+ fn panic(msg: String) $exit $global {
    println(msg)
    exit(1)
}

+ fn raise(code: i32) @willexit $global {
    ext:raise(code.@cast(i32))
}
