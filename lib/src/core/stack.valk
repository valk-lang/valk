//         return Stack {
//             base: base
//             now: base
//         }
//     }
//     fn free() {
//         sys:free(this.base)
//         sys:free(this)
//     }
// }

fn init_stack() {
    // Main stack
    main_stack_pos = @ref(main_stack)
    // Set current stack info
    stack_now = main_stack_pos
    stack_limit = 0.@cast(ptr)
    stack_size = 0
}
