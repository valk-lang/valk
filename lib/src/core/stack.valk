
header "sys" as sys

value GC_STACK_SIZE (32_000)
value STACK_SIZE (96_000)
value STACK_LIMIT_OFFSET (256)

- global main_stack : [ptr x 32_000] (@undefined)
- global main_stack_pos : ptr (@undefined)
- global stack_now : ptr (@undefined)
- global stack_limit : ptr (@undefined)
- global stack_size : uint (@undefined)

