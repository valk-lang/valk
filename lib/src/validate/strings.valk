
+ fn email(email: String) bool {
    //
    let last_alpha = false
    let dot_index = 0
    let at_index = 0
    let last_ch : u8 = 0
    //
    each email as ch, i {
        let lch = last_ch
        last_ch = ch

        // Any part in the domain must start with alpha-numeric character
        if at_index > 0 && !last_alpha && !ch.is_alpha_numeric() : return false

        //
        if ch.is_alpha_numeric() || ch == '-' || (at_index == 0 && ch == '_') {
            last_alpha = true
            continue
        }
        // Check if 2 signs e.g. `..` or `.+`
        if !last_alpha : return false
        last_alpha = false
        //
        if ch == '@' {
            if at_index > 0 : return false
            at_index = i
            continue
        }
        //
        if ch == '.' {
            // After '@', any character before '.' must be alpha-numeric
            if at_index > 0 && !lch.is_alpha_numeric() : return false
            dot_index = i
            continue
        }
        // Only allow + before '@'
        if ch == '+' && at_index == 0 {
            continue
        }
        return false
    }
    // Last character must be alpha-numeric-underscore
    if !last_alpha : return false
    // No '.', no '@' or last '.' position < '@' position
    if dot_index == 0 || at_index == 0 || dot_index < at_index : return false
    // Max 64 characters before '@'
    if at_index > 64 : return false
    // Max 255 characters after '@'
    if (email.length - (at_index + 1)) > 255 : return false

    // Validate tld first/last character
    if !email.get(dot_index + 1).is_alpha() : return false
    if !email.get(email.length - 1).is_alpha_numeric() : return false

    return true
}
