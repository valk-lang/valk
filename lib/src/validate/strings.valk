
+ fn validate_email(email: String) bool {
    //
    let last_alpha = false
    let dot_index = 0
    let at_index = 0
    //
    each email as ch, i {
        if ch.is_alpha_numeric() || ch == '_' {
            last_alpha = true
            continue
        }
        // 2 signs
        if !last_alpha : return false
        last_alpha = false
        //
        if ch == '@' {
            if at_index > 0 : return false
            at_index = i
            continue
        }
        if ch == '.' {
            dot_index = i
            continue
        }
        if ch == '+' {
            continue
        }
        return false
    }
    // Last character must be alpha-numeric-underscore
    if !last_alpha : return false
    // No '.', no '@' or last '.' position < '@' position
    if dot_index == 0 || at_index == 0 || dot_index < at_index : return false

    return true
}
