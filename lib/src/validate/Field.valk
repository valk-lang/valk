
use json

+ global default_translations : Map[String] (.{
    "string_invalid" => "Invalid value"
    "string_min" => "Must be atleast $1 characters long"
    "string_max" => "Cannot be longer than $1 characters"
    "string_email" => "Invalid email address"
    "string_equal" => "Must be equal to '$1'"
    "bool_invalid" => "Invalid value"
    "int_invalid" => "Invalid value"
    "float_invalid" => "Invalid value"
    "array_invalid" => "Invalid value"
    "object_invalid" => "Invalid value"
    "object_missing_field" => "Field should not be empty"
})

+ class Field {
    type: json:TYPE
    s_null: bool (false)
    s_optional: bool (false)
    s_min: ?int
    s_max: ?int
    s_fmin: ?float
    s_fmax: ?float
    custom_validators: ?Array[fn(json:Value)(bool)]
    custom_errors: ?Array[String]
    array_field: ?Field
    object_fields: ?Map[Field]
    s_equals_string: ?String
    default_value: ?json:Value

    + static fn string() SELF {
        return Field {
            type: json:TYPE.string
        }
    }
    + static fn bool() SELF {
        return Field {
            type: json:TYPE.bool
        }
    }
    + static fn int() SELF {
        return Field {
            type: json:TYPE.int
        }
    }
    + static fn float() SELF {
        return Field {
            type: json:TYPE.float
        }
    }
    + static fn array(of: ?Field) SELF {
        return Field {
            type: json:TYPE.array
            array_field: of
        }
    }
    + static fn object(fields: ?Map[Field]) SELF {
        return Field {
            type: json:TYPE.object
            object_fields: fields
        }
    }

    + fn nullable() SELF {
        this.s_null = true
        return this
    }
    + fn optional() SELF {
        this.s_optional = true
        return this
    }
    + fn default(val: $T) SELF {
        let v = json:value(val)
        this.default_value = v
        return this
    }
    + fn min(val: int) SELF {
        this.s_min = val
        return this
    }
    + fn max(val: int) SELF {
        this.s_max = val
        return this
    }
    + fn fmin(val: int) SELF {
        this.s_fmin = val
        return this
    }
    + fn fmax(val: int) SELF {
        this.s_fmax = val
        return this
    }
    + fn email() SELF {
        this.custom(fn(v: json:Value) bool {
            if !v.is_string() : return false
            return email(v.string_value)
        }, "string_email")
        return this
    }
    + fn username(numbers: bool, underscore: bool) SELF {
        this.custom(fn(v: json:Value) bool {
            if !v.is_string() : return false
            each v.string_value as ch {
                if ch.is_alpha() : continue
                if ch.is_number() && numbers : continue
                if ch == '_' && underscore : continue
                return false
            }
            return true
        }, "string_username")
        return this
    }
    + fn equals_string(str: ?String) SELF {
        this.s_equals_string = str
        return this
    }

    + fn custom(func: fn(json:Value)(bool), error: String) SELF {
        let cv = this.custom_validators ?? <{ let a = Array[fn(json:Value)(bool)]{}; this.custom_validators = a; return a }
        let ce = this.get_custom_errors()
        cv.append(func)
        ce.append(error)
        return this
    }

    fn get_custom_errors() Array[String] {
        return this.custom_errors ?? <{ let a = Array[String]{}; this.custom_errors = a; return a }
    }

    + fn validate(data: json:Value, errors: ?Map[String] (null), field_name: ?String (null)) bool {
        let field = field_name ?? "field"
        // Null check
        if this.s_null && data.is_null() : return true
        // Custom validators
        let cv = this.custom_validators
        if isset(cv) {
            let ce = this.get_custom_errors()
            each cv as func, i {
                if !func(data) {
                    if isset(errors) : errors.set(field, ce.get(i) !? "custom_error")
                    return false
                }
            }
        }
        //
        let type = this.type
        if type == json:TYPE.string {
            return this.validate_string(data, errors, field)
        } else if type == json:TYPE.bool {
            return this.validate_bool(data, errors, field)
        } else if type == json:TYPE.int {
            return this.validate_int(data, errors, field)
        } else if type == json:TYPE.float {
            return this.validate_float(data, errors, field)
        } else if type == json:TYPE.array {
            return this.validate_array(data, errors, field)
        } else if type == json:TYPE.object {
            return this.validate_object(data, errors, field)
        }

        if isset(errors) : errors.set(field_name ?? "field", "unknown_type")
        return false
    }

    + fn validate_and_translate(data: json:Value, errors: Map[String], translations: Map[String] (default_translations)) bool {
        let valid = this.validate(data, errors)
        Field.translate_errors(errors, translations)
        return valid
    }

    /////////////////////
    // Casting
    /////////////////////

    + fn try_cast(data: json:Value) json:Value {
        let to = this.type
        let from = data.type
        if to == json:TYPE.string {
            // To String
            if from == json:TYPE.bool : return json:new_string(data.bool_value ? "true" : "false")
            if from == json:TYPE.int : return json:new_string(data)
            if from == json:TYPE.float : return json:new_string(data)
            if from == json:TYPE.null : return json:new_string("null")

        } else if to == json:TYPE.bool {
            // To bool
            if from == json:TYPE.string {
                if data.string_value == "true" : return json:new_bool(true)
                if data.string_value == "false" : return json:new_bool(false)
            }
            if from == json:TYPE.int {
                if data.int_value == 1 : return json:new_bool(true)
                if data.int_value == 0 : return json:new_bool(false)
            }
            if from == json:TYPE.null : return json:new_bool(false)

        } else if to == json:TYPE.int {
            // To int
            if from == json:TYPE.string : return json:new_int(data.string_value.to_int() ! return data)
            if from == json:TYPE.bool : return json:new_int(data.bool_value ? 1 : 0)
            if from == json:TYPE.float : return json:new_int(data.to(int))
            if from == json:TYPE.null : return json:new_int(0)

        } else if to == json:TYPE.float {
            // To float
            if from == json:TYPE.string : return json:new_float(data.string_value.to_float() ! return data)
            if from == json:TYPE.bool : return json:new_float(data.bool_value ? 1 : 0)
            if from == json:TYPE.int : return json:new_float(data.int_value)
            if from == json:TYPE.null : return json:new_float(0)

        } else if to == json:TYPE.array {
            // To array
            if from == json:TYPE.array {
                let subf = this.array_field
                let items = data.array_values
                if isset(subf) && isset(items) {
                    let new_items = Array[json:Value]{}
                    each items as item {
                        new_items.append(subf.try_cast(item))
                    }
                    return json:new_array(new_items)
                }
            }
        } else if to == json:TYPE.object {
            // To object
            if from == json:TYPE.object {
                let subfs = this.object_fields
                let ob = data.object_values ?? Map[json:Value]{}
                if isset(subfs) {
                    let res = json:new_object()
                    each subfs as subf, name {
                        let v = ob.get(name) ! {
                            // Try default value
                            let defv = subf.default_value
                            if isset(defv) : res.set(name, subf.try_cast(defv))
                            continue
                        }
                        res.set(name, subf.try_cast(v))
                    }
                    return res
                }
            }
        }
        return data
    }

    /////////////////////
    // Validate
    /////////////////////

    fn validate_string(data: json:Value, errors: ?Map[String], field_name: String) bool {
        if !data.is_string() {
            if isset(errors) : errors.set(field_name, "string_invalid")
            return false
        }
        let min = this.s_min
        let max = this.s_max
        let str = this.s_equals_string
        let len = data.string_value.length
        if isset(min) && len < min {
            if isset(errors) : errors.set(field_name, "string_min:" + min)
            return false
        }
        if isset(max) && len > max {
            if isset(errors) : errors.set(field_name, "string_max:" + max)
            return false
        }
        if isset(str) && data.string_value != str {
            if isset(errors) : errors.set(field_name, "string_equal:" + str)
            return false
        }
        return true
    }

    fn validate_bool(data: json:Value, errors: ?Map[String], field_name: String) bool {
        if !data.is_bool() {
            if isset(errors) : errors.set(field_name, "bool_invalid")
            return false
        }
        return true
    }

    fn validate_int(data: json:Value, errors: ?Map[String], field_name: String) bool {
        if !data.is_int() {
            if isset(errors) : errors.set(field_name, "int_invalid")
            return false
        }
        let min = this.s_min
        let max = this.s_max
        let val = data.int_value
        if isset(min) && val < min {
            if isset(errors) : errors.set(field_name, "int_min:" + min)
            return false
        }
        if isset(max) && val > max {
            if isset(errors) : errors.set(field_name, "int_max:" + max)
            return false
        }
        return true
    }

    fn validate_float(data: json:Value, errors: ?Map[String], field_name: String) bool {
        if !data.is_float() {
            if isset(errors) : errors.set(field_name, "float_invalid")
            return false
        }
        let min = this.s_min
        let max = this.s_max
        let fmin = this.s_fmin
        let fmax = this.s_fmax
        let val = data.float_value
        if isset(min) && val < min {
            if isset(errors) : errors.set(field_name, "float_min:" + min)
            return false
        }
        if isset(fmin) && val < fmin {
            if isset(errors) : errors.set(field_name, "float_min:" + fmin)
            return false
        }
        if isset(max) && val > max {
            if isset(errors) : errors.set(field_name, "float_max:" + max)
            return false
        }
        if isset(fmax) && val > fmax {
            if isset(errors) : errors.set(field_name, "float_max:" + fmax)
            return false
        }
        return true
    }

    fn validate_array(data: json:Value, errors: ?Map[String], field_name: String) bool {
        if !data.is_array() {
            if isset(errors) : errors.set(field_name, "array_invalid")
            return false
        }
        let min = this.s_min
        let max = this.s_max
        let items = data.array_values
        let len = isset(items) ? items.length : 0
        if isset(min) && len < min {
            if isset(errors) : errors.set(field_name, "array_min:" + min)
            return false
        }
        if isset(max) && len > max {
            if isset(errors) : errors.set(field_name, "array_max:" + max)
            return false
        }
        let subf = this.array_field
        if isset(items) && isset(subf) {
            let is_valid = true
            each items as item, i {
                if !subf.validate(item, errors, "%field_name.%i") : is_valid = false
            }
            if !is_valid : return false
        }
        return true
    }

    fn validate_object(data: json:Value, errors: ?Map[String], field_name: String) bool {
        if !data.is_object() {
            if isset(errors) : errors.set(field_name, "object_invalid")
            return false
        }
        let min = this.s_min
        let max = this.s_max
        let odata = data.object_values
        let len = isset(odata) ? odata.length : 0
        if isset(min) && len < min {
            if isset(errors) : errors.set(field_name, "object_min:" + min)
            return false
        }
        if isset(max) && len > max {
            if isset(errors) : errors.set(field_name, "object_max:" + max)
            return false
        }
        let fields = this.object_fields
        if isset(fields) {
            let is_valid = true
            each fields as subf, fname {
                if !isset(odata) {
                    if isset(errors) : errors.set("%field_name.%fname", "object_missing_field")
                    is_valid = false
                    continue
                }
                let fdata = odata.get(fname) ! {
                    if isset(errors) : errors.set("%field_name.%fname", "object_missing_field")
                    is_valid = false
                    continue
                }
                if !subf.validate(fdata, errors, "%field_name.%fname") : is_valid = false
            }
            if !is_valid : return false
        }
        return true
    }

    /////////////////////
    // Translate
    /////////////////////

    + static fn translate_errors(errors: Map[String], translations: Map[String] (default_translations)) {
        each errors as err, k {
            let parts = err.split(":")
            let name = parts.pop_first() ! continue
            let new = translations.get(name) ! continue
            each parts as val, i {
                new = new.replace("$%{i + 1}", val)
            }
            errors.set(k, new)
        }
    }
}
