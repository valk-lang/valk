
class DateTimeCached {
    time: uint (0)
    cached: bool (false)

    + static fn new() SELF {
        return SELF {}
    }

    fn get_time() uint {
        if this.cached : return this.time
        this.time = microtime()
        this.cached = true
        co fn() {
            sleep_ms(300)
            this.cached = false
        }()
        return this.time
    }
}
