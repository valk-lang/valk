
use ext
use core

+ fn println(msg: String) $global {
    let buf = core:buffer
    buf.clear()
    buf.write_string(msg)
    buf.write_byte('\n')
    write_from_ptr_sync(1, buf.data, buf.length) ! { return }
}

+ fn print(msg: String) $global {
    write_from_ptr_sync(1, msg.data, msg.length) ! { return }
}

+ fn print_from_ptr(adr: ptr, len: uint) {
    write_from_ptr_sync(1, adr, len) ! return
}
