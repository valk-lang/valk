
fn ir_type(ir: IRContext, type: Type) String !Error {
    let t = type.type
    if t == TYPE.void : return "void"
    if t == TYPE.bool : return "i1"
    if t == TYPE.int {
        if type.size == 4 : return "i32"
        return "i32"
        // return "i64"
    }
    if t == TYPE.float : return "f64"
    ir.bug("Unknown IR type (%t)")
}
