
value err_type_error (1)
value err_type_warn (2)

error Error (error) extends (AccessError)
error AccessError (readonly, private)
error InitError (init) payload { msg: String }
error LookupErrorMsg () extends (LookupError) payload { msg: String }

fn init_error(msg: String) !InitError $throw {
    throw .init { msg: msg }
}

class BuildError {
    type: int
    msg: String
}

class ParseError {
    type: int
    chunk: Chunk
    chunk_end: Chunk
    msg: String
}
