
fn ir_func(func: Func) !Error {
    let ast = func.ast()

    let start = IRBlock {
        name: "start"
    }
    let ctx = IRContext {
        build: func.build
        func: func
        active: start
    }
    ctx.blocks.append(start)

    // Gen IR
    ir_ast(ctx, ast.scope) !>

    // Combine
    let final = ByteBuffer.new(8096)
    final.append_str("; Function: ")
    final.append_str(func.display_name)
    final.append_str("\n")

    //
    func.ir = final
}
