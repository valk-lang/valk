
class Pos {
    src: Source
    index: uint (0)
    line: uint (1)
    col: uint (1)

    static fn init(src: Source) SELF {
        return SELF {
            src: src
        }
    }

    fn copy() Pos {
        return Pos {
            src: this.src
            index: this.index
            line: this.line
            col: this.col
        }
    }
}

enum TOK {
    eof
    id
    at_id
    flag
    char
    string
    int
    float
    sign
}

class Tokenizer {
    build: Build
    pos: Pos
    //
    word_index: uint (0)
    word_len: uint (0)
    last_char: u8 (0)
    on_newline: bool (false)

    static fn init(b: Build, pos: Pos) SELF {
        return SELF {
            build: b
            pos: pos
        }
    }

    fn next(update: bool (true)) TOK !Error {
        
        // Position
        let pos = this.pos
        let index = pos.index
        let line = pos.line
        let col = pos.col
        let word_start = index
        // Code
        let src = pos.src
        let code = src.code
        let len = code.length
        let data = code.data
        //
        let on_newline = line == 1 && col == 1

        let t : TOK = TOK.eof

        while true {
            // Detect end of file
            if pos.index >= len {
                t = TOK.eof
                break
            }

            // Get byte
            let ch = @ptrv(data, u8, pos.index++)
            pos.col++

            // Invalid
            if ch > 126 {
                this.build.error_pos("Parse error, unsupported character/byte: " + ch, pos)
            }
            
            // Ignore chars
            if ch < 33 {
                if ch == ' ' || ch == '\r' || ch == '\t' {
                    continue
                }
                if ch == '\n' {
                    on_newline = true
                    pos.line++
                    pos.col = 1
                    this.build.LOC++
                    continue
                }
                this.build.error_pos("Parse error, unsupported character/byte: " + ch, pos)
            }

            // Comment
            if ch == '/' && @ptrv(data, u8, pos.index) == '/' {
                // Skip
                while pos.index < len {
                    if @ptrv(data, u8, pos.index++) == '\n' : break
                }
                on_newline = true
                pos.line++
                pos.col = 1
                continue
            }

            word_start = pos.index - 1

            // Word
            if ch.is_alpha() || ch == '_' || ch == '@' || ch == '$' {
                this.skip_word() !>
                t = ch == '@' ? TOK.at_id : TOK.id
                t = ch == '$' ? TOK.flag : t
                break
            }

            // Number
            if ch.is_number() {
                t = this.skip_number() !>
                break
            }

            // String
            if ch == '\"' {
                word_start = pos.index
                this.skip_string() !>
                t = TOK.string
                break
            }

            // Char
            if ch == '\'' {
                ch = @ptrv(data, u8, pos.index++)
                pos.col++
                if ch == '\'' {
                    this.build.error_pos("Missing character between single quotes", pos)
                }
                if ch == '\\' {
                    ch = @ptrv(data, u8, pos.index++)
                    pos.col++
                    if ch == 'r' : ch = '\r'
                    else if ch == 'n' : ch = '\n'
                    else if ch == 't' : ch = '\t'
                    else if ch == 'b' : ch = '\b'
                    else if ch == 'f' : ch = '\f'
                    else if ch == 'v' : ch = '\v'
                    else if ch == 'a' : ch = '\a'
                    else if ch == 'e' : ch = 27
                }
                if ch == 0 {
                    this.build.error_pos("Unexpected end of file", pos)
                }
                this.last_char = ch
                t = TOK.char
                ch = @ptrv(data, u8, pos.index++)
                if ch != '\'' {
                    this.build.error_pos("Missing single quote, found: '" + ch.to_ascii_string() + "'", pos)
                }
                break
            }

            // Signs
            let next = @ptrv(data, u8, pos.index)
            if ch == '<' && (next == '{' || next == '<' || next == '=') {
                pos.index++
                pos.col++
            } else if ch == '>' && (next == '>' || next == '=') {
                pos.index++
                pos.col++
            } else if ch == '=' && (next == '=' || next == '>') {
                pos.index++
                pos.col++
            } else if ch == '!' && (next == '=' || next == '?' || next == '>' || next == '!') {
                pos.index++
                pos.col++
            } else if ch == '+' && (next == '=' || next == '+') {
                pos.index++
                pos.col++
            } else if ch == '-' && (next == '=' || next == '-' || next == '>') {
                pos.index++
                pos.col++
            } else if ch == '%' && (next == '=') {
                pos.index++
                pos.col++
            } else if ch == '*' && (next == '=') {
                pos.index++
                pos.col++
            } else if ch == '/' && (next == '=') {
                pos.index++
                pos.col++
            } else if ch == '^' && (next == '=') {
                pos.index++
                pos.col++
            } else if ch == '?' && (next == '?' || next == '!') {
                pos.index++
                pos.col++
            } else if ch == '&' && (next == '&' || next == '=') {
                pos.index++
                pos.col++
            } else if ch == '|' && (next == '|' || next == '=') {
                pos.index++
                pos.col++
            } else if ch == '.' && next == '.' && @ptrv(data, u8, pos.index + 1) == '.' {
                pos.index += 2
                pos.col += 2
            }

            // Sign
            t = TOK.sign
            break
        }

        this.word_index = word_start
        this.word_len = t == TOK.eof ? 0 : pos.index - word_start

        // if isset(lsp) {
        //     if this.chunk.fc.is_lsp_file {
        //         this.lsp = lsp.line >= line && lsp.line <= this.line && lsp.col >= col && lsp.col <= this.col
        //     }
        // }

        this.on_newline = on_newline
        if !update {
            pos.index = index
            pos.line = line
            pos.col = col
        }

        return t
    }

    fn skip_word() !Error {
    }
    fn skip_number() TOK !Error {
        return TOK.int
    }
    fn skip_string() !Error {
    }

    fn tok_is(str: String) bool {
        return false
    }
}
