
class IRContext {
    build: Build
    func: Func
    blocks: Array[IRBlock] (.{})
    active: IRBlock
    varc: uint (0)

    fn new_block() IRBlock {
        let b = IRBlock {
            name: "block_" + this.blocks.length
        }
        this.blocks.append(b)
        return b
    }

    fn var() String {
        return "%." + this.varc++
    }
    fn code() ByteBuffer {
        return this.active.code
    }

    fn bug(msg: String) !Error $throw {
        this.build.bug(msg)
    }
}

