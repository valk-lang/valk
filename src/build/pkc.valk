
use helper
use valk:fs

class Pkc {
    build: Build
    name: String
    dir: ?fs:Path
    srcdir: ?fs:Path
    config: ?helper:Config
    namespaces: Map[Nsc] (Map[Nsc]{}) $lazy
    pkc_by_name: Map[Pkc] (Map[Pkc]{}) $lazy
    import_depth: uint
    //
    use_libs: uint (LIBS.none)

    static fn new(b: Build, dir: fs:Path, import_depth: uint) Pkc {

        let srcdir = dir.add("src")
        let config = helper:Config.load(dir.add("valk.json")) !? null
        if isset(config) {
            let src = config.json.get("src")
            if src.is_string() {
                srcdir = helper:resolve(dir + fs:PATH_DIV + src.string())
            }
        }
        let pkc = Pkc {
            build: b
            name: "pkg" + (++b.pkc_name_count)
            dir: dir
            srcdir: srcdir
            config: config
            import_depth: import_depth
        }
        b.pkc_by_dir.set(dir, pkc)
        return pkc
    }

    fn nsc_exists(name: String) bool {
        if name == "main" : return true
        let srcdir = this.srcdir
        if !isset(srcdir) : return false
        let dir = (name == "main") ? srcdir : srcdir.add(name)
        return !fs:is_dir(dir)
    }
    fn pkc_exists(name: String) bool {
        if name == "valk" || name == "main" : return true
        let config = this.config
        if !isset(config) : return false
        return config.has_pkg(name)
    }

    fn load_nsc(name: String, must_exist: bool (true)) Nsc {
        let nsc = this.get_nsc(name, must_exist)
        nsc.load_files()
        return nsc
    }

    fn get_nsc(name: String, must_exist: bool (true)) Nsc {
        this.namespaces.get(name) -> nsc : return nsc
        let srcdir = this.srcdir
        if !isset(srcdir) {
            if name == "main" {
                let nsc = Nsc {
                    pkc: this
                    name: name
                    build: this.build
                    scope: Scope.new(SCOPE.nsc, this.build, null)
                    files_loaded: true
                }
                this.namespaces.set(name, nsc)
                return nsc
            }
            this.build.error("You cannot load a namespace without having a `valk.json` config. This config defines where your namespaces are located. Default location: {config-dir}/src/{namespace}")
        }
        let dir = (name == "main") ? srcdir : srcdir.add(name)
        if must_exist && !fs:is_dir(dir) : this.build.error("Cannot find the '%name' namespace directory: %dir")
        let nsc = Nsc {
            pkc: this
            name: name
            build: this.build
            dir: dir
            scope: Scope.new(SCOPE.nsc, this.build, null)
        }
        this.namespaces.set(name, nsc)
        return nsc
    }

    fn load_sub_pkc(name: String) Pkc {
        if name == "main" {
            return this.build.main_pkc ?! this.build.error("Missing 'main' package")
        }

        let sub = this.pkc_by_name.get(name) !? null
        if isset(sub) : return sub

        let b = this.build
        let dir = ""

        let use_libs : uint = LIBS.none
        if name == "valk" {
            dir = helper:valk_lib_dir()
            use_libs = LIBS.use
        } else {
            let config = this.config
            if !isset(config) {
                this.build.error("Cannot load package '" + name + "', missing config file")
            }
            let d = config.get_package_dir(name) ! {
                if E.code == E.nosrc : this.build.error("The package named '" + name + "' has no valid 'src' defined in your dependencies")
                if E.code == E.noversion : this.build.error("The package named '" + name + "' has no valid 'version' defined in your dependencies")
                this.build.error("No package named '" + name + "' found in your dependencies")
            }
            if !fs:exists(d) : this.build.error("Have you installed all your dependencies? Package directory not found: " + d)
            dir = d
        }

        let p = this.build.pkc_by_dir.get(dir) !? <{
            if b.verbose > 2 : b.log("> Creating package for directory: " + dir)
            let pkc = Pkc.new(b, dir, this.import_depth + 1)
            this.pkc_by_name.set(name, pkc)
            return pkc
        }
        // Library usage
        if use_libs > LIBS.none && use_libs > p.use_libs {
            p.use_libs = use_libs
        }
        if this.use_libs > p.use_libs && name != "valk" {
            p.use_libs = this.use_libs
        }
        if name == "valk" || this.import_depth == 0 {
            p.name = name
        }
        //
        return p
    }

    fn load_all_namespaces() {
        let srcdir = this.srcdir
        if !isset(srcdir) : return
        let nsc = this.load_nsc("main", false)
        let dirs = fs:files_in(srcdir, true, false, true, "")
        each dirs as dir {
            let nsc = this.load_nsc(dir, false)
        }
    }
}

