
fn ir_gep(ctx: IRContext, on: String, type: String, offset: String, offset_type: String) String {
    let var = ctx.var()
    let code = ctx.code()
    code.append_str("  ")
    code.append_str(var)
    code.append_str(" = getelementptr ")
    code.append_str(type)
    code.append_str(", ptr ")
    code.append_str(on)
    code.append_str(", ")
    code.append_str(offset_type)
    code.append_str(" ")
    code.append_str(offset)
    code.append_str("\n")
    return var
}
