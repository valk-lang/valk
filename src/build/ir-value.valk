
fn ir_value(ctx: IRContext, v: Value) String !Error {

    let t = v.type

    if t == VAL.string {
        let str = v.str ?! ctx.bug("Missing global string object")
        let b = ctx.active
        let on = str.ir_name
        return ir_gep(ctx, on, "ptr", 1, "i64")
    }

    ctx.bug("Unhandled IR value type (%t)")
}
