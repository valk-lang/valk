
extend Exp {

    fn read_body_ast() !Error {
        //
        if isset(this.exp1) || isset(this.exps1) : return

        let pos = this.pos1 ?! this.bug("Missing body code position")
        let t = this.build.tokenizer(pos)

        let exps = Array[Exp]{}
        while true {
            if t.next_is("}") {
                t.next() !>
                break
            }
            let v = t.read_value() !>
            exps.append(v)
        }

        this.exps1 = exps
    }
}