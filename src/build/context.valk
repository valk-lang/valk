
class Context {
    build: Build
    unit: Unit
    func: Func
    fast: FuncAst

    static fn for_func(func: Func) SELF {
        let ctx = SELF {
            build: func.build
            unit: func.unit
            func: func
            fast: func.ast()
        }
        return ctx
    }

    // fn uses_func(func: Func) {
    //     let infunc = this.func
    //     let fast = infunc.ast()
    // }
}
