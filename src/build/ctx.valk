
class Ctx {
    b: Build
    func: ?FuncNew
    tkn: ?Tokenizer

    fn value(type: VT) Vnew {
        let v = Vnew {
            type: type
            rett: this.b.type_void()
        }
        let tkn = this.tkn
        if isset(tkn) {
            v.src = tkn.src
            v.i = tkn.i
            v.len = tkn.word_len
            v.lines_before = tkn.lines_before
        }
        return v
    }
}
